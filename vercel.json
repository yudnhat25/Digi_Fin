{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/[...path].ts": {
      "includeFiles": "server/**"
    }
  },
  "rewrites": [
    { "source": "/docs", "destination": "/api/docs" },
    { "source": "/openapi.yaml", "destination": "/api/openapi.yaml" }
  ]
}
